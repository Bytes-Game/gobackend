{
  "title": "devf backend overview",
  "uid": "devf-overview",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "tags": ["devf", "backend"],
  "templating": {
    "list": [
      {
        "name": "endpoint",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(devf_http_requests_total, path)",
        "includeAll": true,
        "multi": true
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "RPS (5m)",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "sum(rate(devf_http_requests_total[5m]))",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "5xx rate",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "sum(rate(devf_http_requests_total{status=\"5xx\"}[5m])) / clamp_min(sum(rate(devf_http_requests_total[5m])), 1)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 0.01, "color": "red" }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "feed/smart p95 (5m)",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(devf_feed_latency_seconds_bucket{endpoint=\"/api/v1/feed/smart\"}[5m])))",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "feed/smart p99 (5m)",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(devf_feed_latency_seconds_bucket{endpoint=\"/api/v1/feed/smart\"}[5m])))",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "HTTP requests by status class",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum by (status) (rate(devf_http_requests_total[1m]))",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Feed latency p50 / p95 / p99",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le, endpoint) (rate(devf_feed_latency_seconds_bucket[1m])))",
          "legendFormat": "{{endpoint}} p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le, endpoint) (rate(devf_feed_latency_seconds_bucket[1m])))",
          "legendFormat": "{{endpoint}} p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le, endpoint) (rate(devf_feed_latency_seconds_bucket[1m])))",
          "legendFormat": "{{endpoint}} p99",
          "refId": "C"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Signal capture per minute",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum by (kind) (rate(devf_signal_capture_total[1m]))",
          "legendFormat": "{{kind}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Analytics job outcomes",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum by (job, outcome) (increase(devf_analytics_job_total[15m]))",
          "legendFormat": "{{job}} / {{outcome}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Bandit writes (ok vs error)",
      "gridPos": { "x": 0, "y": 20, "w": 8, "h": 6 },
      "targets": [
        {
          "expr": "sum by (outcome) (rate(devf_bandit_writes_total[1m]))",
          "legendFormat": "{{outcome}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "LTR flushes & updates",
      "gridPos": { "x": 8, "y": 20, "w": 8, "h": 6 },
      "targets": [
        {
          "expr": "sum by (outcome) (rate(devf_ltr_flushes_total[5m]))",
          "legendFormat": "flush {{outcome}}",
          "refId": "A"
        },
        {
          "expr": "sum by (cohort) (devf_ltr_updates)",
          "legendFormat": "updates {{cohort}}",
          "refId": "B"
        }
      ]
    },
    {
      "id": 11,
      "type": "table",
      "title": "Top endpoints by RPS",
      "gridPos": { "x": 16, "y": 20, "w": 8, "h": 6 },
      "targets": [
        {
          "expr": "topk(10, sum by (path) (rate(devf_http_requests_total[5m])))",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ]
    }
  ]
}
