# Template for the worker's .env file. Copy this to .env and fill in
# the actual values from your Render dashboard. The .env file itself
# must NEVER be committed to git (the worker dir's .gitignore blocks it).
#
# All values must match the corresponding env vars on the main backend
# service so the worker can authenticate with the API + upload to the
# same R2 bucket the backend reads from.

BACKEND_URL=https://gobackend-9nd8.onrender.com
HLS_WORKER_TOKEN=paste-the-64-char-hex-string-here

# Copy these four straight from gobackend-9nd8 → Environment on Render
R2_ACCOUNT_ID=
R2_BUCKET=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# Optional: only set this if you've put a custom domain in front of R2
# (e.g. https://media.devf.com). If blank, the worker auto-derives the
# pub-<account>.r2.dev URL.
R2_PUBLIC_BASE_URL=
